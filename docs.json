	"navigation": {
		"tabs": [
			{
				"tab": "使用指南",
				"groups": [
					{
						"group": "使用指南",
						"pages": ["index"]
					},
					{
						"group": "Agent 生态",
						"pages": ["indexes/agent-ecosystem"]
					}
				]
			}
		],
		"global": {
			"anchors": [
				{
					"anchor": "文档",
					"href": "https://mintlify.com/docs",
					"icon": "book-open-cover"
				},
				{
					"anchor": "博客",
					"href": "https://mintlify.com/blog",
					"icon": "newspaper"
				}
			]
		}
	},
	"logo": {
		"light": "/logo/light.svg",
