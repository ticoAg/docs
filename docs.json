		{
			"source": "/api-reference/endpoint/create",
			"destination": "/usage-guide/api-reference/endpoint/create",
			"permanent": true
		},
		{
			"source": "/api-reference/endpoint/delete",
			"destination": "/usage-guide/api-reference/endpoint/delete",
			"permanent": true
		},
		{
			"source": "/api-reference/endpoint/webhook",
			"destination": "/usage-guide/api-reference/endpoint/webhook",
			"permanent": true
		},
		{
			"source": "/api-reference/openapi.json",
			"destination": "/usage-guide/api-reference/openapi.json",
			"permanent": true
		}
	],
	"navigation": {
		"tabs": [
			{
				"tab": "资源目录",
				"groups": [
					{
						"group": "开始",
						"pages": ["index"]
					},
					{
						"group": "生态索引",
						"root": "indexes/agent-ecosystem",
						"expanded": true,
						"pages": [
							{
								"group": "智能体",
								"icon": "robot",
								"expanded": true,
								"pages": [
									"indexes/agent-cli",
									"indexes/agent-orchestration",
									"indexes/agent-frameworks"
								]
							},
							{
								"group": "能力层",
								"icon": "wrench",
								"expanded": true,
								"pages": [
									"indexes/tools",
									"indexes/mcp",
									"indexes/context-engineering",
									"indexes/sandboxes",
									"indexes/gateways"
								]
							},
							{
								"group": "规则 / 方法",
								"icon": "sparkles",
								"expanded": true,
								"pages": [
									"indexes/skills",
									"indexes/skill-directory",
									"indexes/prompts"
								]
							}
						]
					},
					{
						"group": "实用笔记",
						"expanded": true,
						"pages": [
							"notes/cloudflare-free-stack",
							"notes/edgeone-tccli-stack",
							"notes/yunxiao-devops-stack",
							"notes/lark-cli-mcp-stack"
						]
					}
				]
			}
		],
		"global": {
			"anchors": [
				{
					"anchor": "GitHub 星标",
					"href": "https://github.com/ticoAg?tab=stars",
					"icon": "star"
				},
				{
					"anchor": "技能清单",
					"href": "https://github.com/stars/ticoAg/lists/skills",
					"icon": "sparkles"
				}
			]
		}
	},
	"logo": {
		"light": "/logo/light.svg",
		"dark": "/logo/dark.svg"
	},
	"navbar": {
		"links": [
			{
				"label": "GitHub 主页",
				"href": "https://github.com/ticoAg?tab=stars"
			}
		],
		"primary": {
			"type": "button",
			"label": "浏览索引",
			"href": "/indexes/agent-ecosystem"
		}
	},
	"contextual": {
		"options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
	},
	"footer": {
		"socials": {
			"github": "https://github.com/ticoAg"
		}
	}
}
