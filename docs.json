	},
	"navbar": {
		"links": [
			{
				"label": "支持",
				"href": "mailto:hi@mintlify.com"
			}
		],
		"primary": {
			"type": "button",
			"label": "控制台",
			"href": "https://dashboard.mintlify.com"
		}
	},
	"contextual": {
		"options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
	},
	"footer": {
