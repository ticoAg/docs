		"primary": "#0F766E",
		"light": "#14B8A6",
		"dark": "#115E59"
	},
	"favicon": "/favicon.svg",
	"redirects": [
		{ "source": "/quickstart", "destination": "/usage-guide/getting-started/quickstart", "permanent": true },
		{ "source": "/development", "destination": "/usage-guide/getting-started/development", "permanent": true },
		{ "source": "/essentials/settings", "destination": "/usage-guide/customization/settings", "permanent": true },
		{ "source": "/essentials/navigation", "destination": "/usage-guide/customization/navigation", "permanent": true },
		{ "source": "/essentials/markdown", "destination": "/usage-guide/writing-content/markdown", "permanent": true },
		{ "source": "/essentials/code", "destination": "/usage-guide/writing-content/code", "permanent": true },
		{ "source": "/essentials/images", "destination": "/usage-guide/writing-content/images", "permanent": true },
		{
			"source": "/essentials/reusable-snippets",
			"destination": "/usage-guide/writing-content/reusable-snippets",
			"permanent": true
		},
		{
			"source": "/getting-started/quickstart",
			"destination": "/usage-guide/getting-started/quickstart",
			"permanent": true
		},
		{
			"source": "/getting-started/development",
			"destination": "/usage-guide/getting-started/development",
			"permanent": true
		},
		{ "source": "/customization/settings", "destination": "/usage-guide/customization/settings", "permanent": true },
		{
			"source": "/customization/navigation",
			"destination": "/usage-guide/customization/navigation",
			"permanent": true
		},
		{
			"source": "/writing-content/markdown",
			"destination": "/usage-guide/writing-content/markdown",
			"permanent": true
		},
		{ "source": "/writing-content/code", "destination": "/usage-guide/writing-content/code", "permanent": true },
		{ "source": "/writing-content/images", "destination": "/usage-guide/writing-content/images", "permanent": true },
		{
			"source": "/writing-content/reusable-snippets",
			"destination": "/usage-guide/writing-content/reusable-snippets",
			"permanent": true
		},
		{
			"source": "/api-reference/introduction",
			"destination": "/usage-guide/api-reference/introduction",
			"permanent": true
		},
		{
			"source": "/api-reference/endpoint/get",
			"destination": "/usage-guide/api-reference/endpoint/get",
			"permanent": true
